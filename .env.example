# OpenAI API Key (required) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Port the server listens on (optional, default: 3000)
PORT=3000

# Whisper transcription language as ISO-639-1 code, e.g. "de", "en".
# Use "auto" to let Whisper detect the language. (optional, default: de)
WHISPER_LANGUAGE=de

# Allowed CORS origin for the browser extension.
# Use "*" to allow any origin. (optional, default: https://web.whatsapp.com)
ALLOWED_ORIGIN=https://web.whatsapp.com
